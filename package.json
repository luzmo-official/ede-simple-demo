{
  "name": "cumul.io-integration",
  "version": "1.0.0",
  "description": "Cumul.io sample integration app",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run build:client",
    "build:client": "esbuild public/js/main.ts --bundle --outfile=public/js/bundle.js --format=esm --platform=browser",
    "build:client:watch": "esbuild public/js/main.ts --bundle --outfile=public/js/bundle.js --format=esm --platform=browser --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json --noEmit",
    "start": "npm run build && node dist/server.js",
    "dev": "npm run build:client && concurrently \"npm run build:client:watch\" \"tsx watch src/server.ts\""
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^5.15.3",
    "@luzmo/embed": "^6.11.0",
    "@luzmo/nodejs-sdk": "^2.1.1",
    "bootstrap": "^5.0.2",
    "compression": "^1.7.3",
    "dotenv": "10.0.0",
    "ejs": "3.1.6",
    "express": "^4.16.3",
    "passport-local": "^1.0.0",
    "request": "^2.88.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/ejs": "^3.1.5",
    "@types/connect-livereload": "^0.6.2",
    "@types/express": "^4.17.21",
    "@types/livereload": "^0.9.5",
    "@types/node": "^20.14.0",
    "concurrently": "^9.0.0",
    "connect-livereload": "^0.6.1",
    "esbuild": "^0.23.0",
    "eslint": "^7.30.0",
    "livereload": "^0.9.3",
    "nodemon": "^2.0.9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
